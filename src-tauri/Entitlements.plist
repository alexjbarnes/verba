<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<key>com.apple.security.device.audio-output</key>
	<true/>
	<key>com.apple.security.device.microphone</key>
	<true/>
	<!-- The bundled binary loads Microsoft's libonnxruntime.dylib (a different
	     signing identity than our ad-hoc signature); hardened-runtime library
	     validation would otherwise refuse it with a "different Team IDs" error. -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
